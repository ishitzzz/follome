{
  "manifest_version": 3,
  "name": "FolloMe — AI Browser Assistant",
  "version": "1.0.0",
  "description": "An AI browser assistant that follows you across tabs and helps you complete tasks in real-time.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["utils/storage.js", "utils/analytics.js", "utils/context-extractor.js", "utils/element-matcher.js", "brain/guidance-state.js", "brain/recovery-engine.js", "content/cursor-guide.js", "content/passive-tracker.js", "content/overlay.js", "content/speech.js", "content/content.js"],
      "css": ["content/overlay.css", "content/cursor-guide.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["utils/storage.js", "utils/analytics.js", "adapters/base-adapter.js", "adapters/chatgpt-adapter.js", "adapters/router.js", "watchers/conversation-watcher.js", "content/ai-content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": ["utils/storage.js", "utils/analytics.js", "adapters/base-adapter.js", "adapters/gemini-adapter.js", "adapters/router.js", "watchers/conversation-watcher.js", "content/ai-content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": ["utils/storage.js", "utils/analytics.js", "adapters/base-adapter.js", "adapters/claude-adapter.js", "adapters/router.js", "watchers/conversation-watcher.js", "content/ai-content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "start_listening": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Start Learning Mode Voice Input",
      "global": true
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
